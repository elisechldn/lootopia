  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo test",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
