# Variables consommées par compose.yml (à la racine du repo).
# Pour la config applicative (JWT, S3 endpoints, etc.), voir apps/api/.env.example
# et apps/web/.env.example, apps/pwa/.env.example.

# Postgres — credentials de la base lancée par le service `db`.
POSTGRES_USER=lootopia
POSTGRES_PASSWORD=lootopia
POSTGRES_DB=lootopia

# pgAdmin — UI d'admin de la base, exposée sur http://localhost:5050.
PGADMIN_DEFAULT_EMAIL=lootopia@lootopia.com
PGADMIN_DEFAULT_PASSWORD=lootopia

# MinIO — stockage objet S3-compatible, console sur http://localhost:9001.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=lootopia-public

# JWT — clé de signature des tokens d'authentification, injectée dans le service `api`.
# OBLIGATOIRE — l'API plante au boot si absente (cf. requireEnv dans apps/api/src/config/env.ts).
# Génère une vraie valeur en prod : `openssl rand -base64 48`
JWT_SECRET=changeMe
