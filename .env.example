DATABASE_URL="postgresql://user:password@localhost:5432/lootopia"
JWT_SECRET="your-jwt-secret-at-least-32-chars"
SESSION_SECRET="your-session-secret-at-least-32-chars"
PORT=3000

# OIDC SSO (optionnel : défaut http://localhost:3000/oidc)
OIDC_ISSUER="http://localhost:3000/oidc"
# Mettre true si l’API est derrière un reverse proxy (nginx, etc.)
TRUST_PROXY=false

