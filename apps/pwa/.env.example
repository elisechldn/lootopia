# URL de l'API utilisée CÔTÉ SERVEUR (SSR, server actions, route handlers)
# ET comme cible du rewrite `/api/*` défini dans next.config.js.
# - Local (dev hors Docker) : http://localhost:8000
# - Docker (compose)        : http://api:8000 (nom du service, réseau interne Docker)
API_URL=http://localhost:8000

# URL de l'API utilisée CÔTÉ CLIENT (navigateur).
# Valeur recommandée : "/api" — les requêtes passent alors par le rewrite Next.js
# qui les proxyfie vers ${API_URL}. Avantages :
#   - évite CORS (même origine) ;
#   - évite le mixed content quand la PWA est servie en HTTPS (ex: ngrok sur smartphone)
#     alors que l'API tourne en HTTP.
# Mettre une URL absolue (http://localhost:8000) uniquement si le proxy n'est pas souhaité.
# ⚠️ Variable "NEXT_PUBLIC_*" : elle est inlinée dans le bundle AU BUILD.
#    En Docker, elle doit être passée via `build.args` (voir compose.yml),
#    PAS uniquement via `environment`.
NEXT_PUBLIC_API_URL=/api

# Base URL des assets (images de couverture, modèles .glb) servis par MinIO/S3.
# Valeur recommandée : "/assets" — passe par le rewrite Next.js qui proxy vers MinIO.
# Avantages identiques à NEXT_PUBLIC_API_URL : même origine, pas de CORS,
# pas de mixed content en HTTPS, et fonctionne quel que soit l'hôte (localhost,
# IP LAN d'un téléphone, ngrok…).
# ⚠️ "NEXT_PUBLIC_*" : inlinée au build, à passer via build.args en Docker.
NEXT_PUBLIC_ASSETS_BASE_URL=/assets

# Cible interne du rewrite "/assets/*" — utilisée UNIQUEMENT côté serveur Next.
# - Local (npm run dev) : http://localhost:9000
# - Docker (compose)    : http://minio:9000 (DNS interne)
MINIO_INTERNAL_URL=http://localhost:9000
S3_BUCKET=lootopia-public

# Clés VAPID pour les Web Push Notifications.
# Générer une paire avec : `npx web-push generate-vapid-keys`
# - NEXT_PUBLIC_VAPID_PUBLIC_KEY : exposée au client (subscription côté navigateur).
# - VAPID_PRIVATE_KEY            : secrète, ne JAMAIS exposer au client.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
