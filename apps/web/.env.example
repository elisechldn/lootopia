# URL de l'API utilisée CÔTÉ SERVEUR (SSR, server actions, route handlers).
# - Local (dev hors Docker) : http://localhost:8000
# - Docker (compose)        : http://api:8000 (nom du service, réseau interne Docker)
API_URL=http://localhost:8000

# URL de l'API utilisée CÔTÉ CLIENT (navigateur).
# Doit être joignable depuis la machine de l'utilisateur final.
# ⚠️ Variable "NEXT_PUBLIC_*" : elle est inlinée dans le bundle AU BUILD.
#    En Docker, elle doit donc être passée via `build.args` (voir compose.yml),
#    PAS uniquement via `environment` (qui n'agirait que sur le runtime serveur).
NEXT_PUBLIC_API_URL=http://localhost:8000
