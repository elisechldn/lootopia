model User {
  id             Int       @id @default(autoincrement())
  username       String
  firstname      String
  lastname       String
  email          String    @unique
  password       String
  role           Role      @default(PLAYER)
  picture        String?
  lastConnection DateTime?
  country        String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  hunts          Hunt[]
  participations Participation[]
}
