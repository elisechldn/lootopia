generator client {
  provider        = "prisma-client"
  // output          = "../generated"
  output          = "../../../../../../packages/types/src/prismaModels"
  moduleFormat    = "cjs"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [postgis]
}

enum Role {
  ADMIN
  PARTNER
  PLAYER
}
