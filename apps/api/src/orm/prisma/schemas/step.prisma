model Step {
  id           Int          @id @default(autoincrement())
  orderNumber  Int
  title        String
  location     Unsupported("GEOGRAPHY(Point, 4326)")?
  radius       Int          @default(50)
  actionType   ActionType   @default(GPS)
  arMarkerUrl  String?
  arContent    String?
  qrCodeValue  String?
  points       Int          @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  refHunt      Int
  hunt         Hunt         @relation(fields: [refHunt], references: [id], onDelete: Cascade)
  clues        Clue[]
  progresses   Progress[]

  @@unique([refHunt, orderNumber])
}

enum ActionType {
  GPS
  QR_CODE
  AR
  RIDDLE
}
