# Port d'écoute du serveur NestJS.
# En local comme en Docker (voir compose.yml), l'API écoute sur 8000.
PORT=8000

# URL de connexion PostgreSQL (format natif Prisma).
# - Local (dev hors Docker) : pointer vers la base exposée par `docker compose up db`
#   -> postgresql://<POSTGRES_USER>:<POSTGRES_PASSWORD>@localhost:5432/<POSTGRES_DB>
# - Docker (compose) : l'URL est injectée automatiquement par compose.yml
#   à partir de POSTGRES_USER/POSTGRES_PASSWORD/POSTGRES_DB (hôte `db`, réseau interne).
# Doc : https://pris.ly/d/connection-strings
DATABASE_URL="postgresql://lootopia:lootopia@localhost:5432/lootopia?schema=public"

# Clé de signature des JWT (auth + guards).
# OBLIGATOIRE en production. En dev, un fallback 'dev-secret-change-in-prod' est utilisé
# si absent — à NE JAMAIS conserver en prod. Générer une valeur forte (>=32 caractères),
# par exemple : `openssl rand -base64 48`.
JWT_SECRET="change-me-in-prod-at-least-32-chars"
